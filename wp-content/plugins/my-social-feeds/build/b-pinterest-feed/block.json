{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "bpf/b-pinterest-feed",
  "version": "1.0.0",
  "title": "B Pinterest Feed",
  "category": "widgets",
  "description": "Embed Pinterest Pins In Your Webiste",
  "parent": [
    "msfbp/my-social-feeds"
  ],
  "keywords": [
    "pinterest",
    "feed",
    "social",
    "media"
  ],
  "textdomain": "b-pinterest-feed",
  "attributes": {
    "align": {
      "type": "string",
      "default": ""
    },
    "accountInfo": {
      "type": "object",
      "default": {
        "userName": "",
        "boardName": ""
      }
    },
    "layout": {
      "type": "string",
      "default": "default"
    },
    "columns": {
      "type": "object",
      "default": {
        "desktop": 3,
        "tablet": 2,
        "mobile": 1
      }
    },
    "columnGap": {
      "type": "string",
      "default": "30px"
    },
    "rowGap": {
      "type": "string",
      "default": "30px"
    },
    "elements": {
      "type": "object",
      "default": {
        "isProfile": true,
        "isPins": true,
        "isImage": true,
        "isName": true,
        "isDesc": true,
        "isFollower": true,
        "isPin": true,
        "isBtn": true
      }
    },
    "fancyApps": {
      "type": "object",
      "default": {
        "left": {
          "infobar": true
        },
        "middle": {
          "zoomIn": false,
          "zoomOut": false,
          "toggle1to1": false,
          "rotateCCW": false,
          "rotateCW": false,
          "flipX": false,
          "flipY": false
        },
        "right": {
          "slideshow": true,
          "thumbs": false,
          "close": true
        }
      }
    },
    "slider": {
      "type": "object",
      "default": {
        "isAutoPlay": false,
        "autoPlayDelay": 2000,
        "isMouseWheel": false,
        "effect": "none",
        "isGrabCursor": false
      }
    },
    "pinCoverImage": {
      "type": "object",
      "default": {
        "ratio": "9:16"
      }
    },
    "profileWrapper": {
      "type": "object",
      "default": {
        "background": {
          "color": "#fff"
        }
      }
    },
    "image": {
      "type": "object",
      "default": {
        "isOverly": false,
        "overlyColor": "#0000002e",
        "isTransform": false,
        "border": {
          "radius": "0px",
          "color": "#000",
          "width": "0px"
        }
      }
    },
    "name": {
      "type": "object",
      "default": {
        "typo": {
          "fontSize": {
            "desktop": 18,
            "tablet": 16,
            "mobile": 15
          },
          "fontWeight": 500,
          "fontFamily": "Arial, sans-serif",
          "lineHeight": "135%"
        },
        "color": "#000"
      }
    },
    "about": {
      "type": "object",
      "default": {
        "typo": {
          "fontSize": {
            "desktop": 16,
            "tablet": 14,
            "mobile": 14
          },
          "fontWeight": 400,
          "fontFamily": "Arial, sans-serif",
          "lineHeight": "135%"
        },
        "color": "#000"
      }
    },
    "countArea": {
      "type": "object",
      "default": {
        "typo": {
          "fontSize": {
            "desktop": 14,
            "tablet": 14,
            "mobile": 14
          },
          "fontWeight": 400,
          "fontFamily": "Arial, sans-serif",
          "lineHeight": "135%"
        },
        "color": "#000"
      }
    },
    "button": {
      "type": "object",
      "default": {
        "typo": {
          "fontSize": {
            "desktop": 16,
            "tablet": 14,
            "mobile": 14
          },
          "fontWeight": 500,
          "fontFamily": "Arial, sans-serif",
          "lineHeight": "135%"
        },
        "colors": {
          "color": "#fff",
          "bg": "#000"
        },
        "hoverColors": {
          "color": "#000",
          "bg": "#e3e3e3"
        },
        "padding": {
          "desktop": {
            "top": "5px",
            "right": "10px",
            "bottom": "5px",
            "left": "10px"
          },
          "tablet": {
            "top": "5px",
            "right": "10px",
            "bottom": "5px",
            "left": "10px"
          },
          "mobile": {
            "top": "5px",
            "right": "10px",
            "bottom": "5px",
            "left": "10px"
          }
        },
        "border": {
          "radius": "0px",
          "color": "#000",
          "width": "0px"
        }
      }
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false
  },
  "example": {
    "attributes": {}
  },
  "editorScript": [
    "file:./index.js",
    "ttp-script",
    "jquery",
    "justified"
  ],
  "editorStyle": [
    "file:./index.css",
    "justified"
  ],
  "style": [
    "file:./view.css",
    "fancyapps",
    "justified"
  ],
  "render": "file:./render.php",
  "viewScript": [
    "file:./view.js",
    "ttp-script",
    "fancyapps",
    "jquery",
    "justified"
  ]
}